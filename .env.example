# ===================================
# AI Video Generator - Environment Variables
# ===================================

# Groq API (Free - Get from: https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# YouTube API (Free - Get from: https://console.cloud.google.com/)
# Download client_secret.json and paste content here
YOUTUBE_CLIENT_SECRET={"installed":{"client_id":"...","client_secret":"..."}}

# Optional: HuggingFace Token (for better image quality)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Video Settings
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS=24

# TTS Settings (Edge TTS voices)
# English: en-US-ChristopherNeural, en-US-JennyNeural
# Persian: fa-IR-DilaraNeural, fa-IR-FaridNeural
TTS_VOICE=en-US-ChristopherNeural

# YouTube Upload Settings
YOUTUBE_PRIVACY_STATUS=public
YOUTUBE_CATEGORY_ID=22

# Topic (can be randomized in code)
DEFAULT_TOPIC=amazing space facts
